# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# IDE
# .vscode/settings.json ships in the template (carries shipped Claude Code permission-mode
# recommendations — see TROUBLESHOOTING.md "Permissions / bypass / statusline" for the typo
# fix forkers need). Other .vscode/ content is developer-machine-specific.
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
.quarto/

# quality_reports/ — per-project session logs, plans, specs, merges.
# The directory structure ships in the template (via .gitkeep), but the
# content is PROJECT-INTERNAL and shouldn't be inherited by forks.
quality_reports/plans/*
quality_reports/specs/*
quality_reports/session_logs/*
quality_reports/merges/*
quality_reports/decisions/*
quality_reports/checkpoints/*
quality_reports/preregistrations/*
!quality_reports/plans/.gitkeep
!quality_reports/specs/.gitkeep
!quality_reports/session_logs/.gitkeep
!quality_reports/merges/.gitkeep
!quality_reports/decisions/.gitkeep
!quality_reports/checkpoints/.gitkeep
!quality_reports/preregistrations/.gitkeep

# R analysis outputs (generated artifacts; keep scripts, ignore outputs)
scripts/R/_outputs/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds

# =============================================================================
# Stata
# =============================================================================

# Session logs — large, machine-specific; profile.do writes them to Stata/log/.
Stata/log/*.log
Stata/log/*.smcl
!Stata/log/.gitkeep

# Stata temp files
*.tmp
__*.dta
*.~stata

# Stata package code lives in Stata/ado/ (project-local PERSONAL dir).
# Keep the directory itself; the package contents are reinstalled from
# `do install_packages.do` so don't commit the package binaries.
Stata/ado/*
!Stata/ado/.gitkeep

# =============================================================================
# Data — raw is restricted/proprietary by default; derived is opt-in commit
# =============================================================================

# Raw data: NEVER commit. Add documented sources to Data/README.md.
Data/raw/*
!Data/raw/.gitkeep

# Derived data: commit small files (<25MB each, <100MB total) deliberately.
# Default-ignore .dta and large CSVs; whitelist specific files you want in
# the repo via `!Data/derived/<filename>` exceptions below.
Data/derived/*.dta
Data/derived/*.csv
Data/derived/*.parquet
!Data/derived/.gitkeep
# Example: uncomment a line to commit a specific derived file
# !Data/derived/county_panel_clean.dta

